  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"**/*.{ts,tsx,js,jsx}\"",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:gi-15": "playwright test gi-15-*.spec.ts",
    "test:gi-15:ui": "playwright test gi-15-*.spec.ts --ui",
    "test:gi-15:report": "playwright test gi-15-*.spec.ts --reporter=html",
    "test:gi-15:group1": "playwright test gi-15-frame-meta-validation.spec.ts",
    "test:gi-15:group2": "playwright test gi-15-button-validation.spec.ts",
    "test:gi-15:group3": "playwright test gi-15-og-image-integrity.spec.ts",
    "test:gi-15:group4": "playwright test gi-15-miniapp-frame-parity.spec.ts",
    "test:gi-15:group5": "playwright test gi-15-input-validation.spec.ts",
    "test:gi-15:group6": "playwright test gi-15-performance-timeouts.spec.ts",
    "test:gi-15:group7": "playwright test gi-15-warpcast-simulation.spec.ts",
    "test:gi-15:group8": "playwright test gi-15-regression-tests.spec.ts",
    "test:devices": "./scripts/test-devices.sh all",
    "test:devices:quick": "./scripts/test-devices.sh quick",
    "test:devices:desktop": "./scripts/test-devices.sh desktop",
    "test:devices:mobile": "./scripts/test-devices.sh mobile",
    "test:devices:ios": "./scripts/test-devices.sh ios",
    "test:devices:android": "./scripts/test-devices.sh android",
    "test:devices:tablet": "./scripts/test-devices.sh tablet",
    "test:mobile-onboarding": "playwright test mobile-onboarding --project=mobile-iphone-12 --project=mobile-pixel-5 --project=mobile-small",
    "lighthouse": "lhci autorun",
    "lighthouse:open": "lhci autorun && open .lighthouseci/*/lhr-*.html",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "vercel:dev": "vercel dev",
    "dev:tunnel": "node scripts/dev-tunnel.mjs",
    "vercel:deploy": "vercel --prod",
    "bot": "tsx ./bot/index.ts",
    "tips:worker": "tsx ./scripts/tipHubWorker.ts",
    "automation:run": "tsx ./scripts/automation/run-queue.ts",
    "notifications:gm-reminders": "tsx ./scripts/automation/send-gm-reminders.ts",
    "test:badge-minting": "tsx ./scripts/test-badge-minting.ts",
    "test:cache": "tsx ./scripts/test-frame-cache.ts",
    "warmup": "./scripts/warmup-frames.sh",
    "warmup:local": "./scripts/warmup-frames.sh http://localhost:3002",
    "prebuild": "npm run clean && npm run lint",
    "clean": "rimraf .next"
  },
