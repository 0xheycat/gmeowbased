DB_NAME=squid
DB_PORT=23798
GQL_PORT=4350

# JSON-RPC node endpoints for Base mainnet
# Multiple free/public endpoints for automatic failover
# Primary: Coinbase official (most reliable)
RPC_BASE_HTTP=https://mainnet.base.org
# Backup 1: LlamaNodes (fast, reliable)
RPC_BASE_HTTP_2=https://base.llamarpc.com
# Backup 2: PublicNode (high rate limits)
RPC_BASE_HTTP_3=https://base-rpc.publicnode.com
# Backup 3: BlastAPI (reliable fallback)
RPC_BASE_HTTP_4=https://base-mainnet.public.blastapi.io

RPC_ETH_HTTP=https://mainnet.base.org

# Uncommenting this line enables the debug mode
# More info at https://docs.subsquid.io/basics/logging/
#SQD_DEBUG=*
