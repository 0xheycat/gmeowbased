/**
 * Icons Index - Centralized Icon Exports
 * 
 * This file provides a single import point for all MUI Material Icons.
 * All icons are re-exported from @mui/icons-material for consistency.
 * 
 * Usage:
 * import { CheckCircleIcon, CancelIcon, MonetizationOnIcon } from '@/components/icons';
 * 
 * Benefits:
 * - Single source of truth for icon imports
 * - Consistent naming with "Icon" suffix
 * - Direct MUI imports for tree-shaking
 * - Easy to add new icons without breaking existing code
 * 
 * Browse all available icons: https://mui.com/material-ui/material-icons/
 */

