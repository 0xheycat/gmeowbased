/**
 * ============================================================================
 * USAGE EXAMPLES
 * ============================================================================
 * 
 * // Import icons from the centralized index:
 * import { CheckCircleIcon, CancelIcon, MonetizationOnIcon } from '@/components/icons';
 * 
 * // Use in components:
 * <CheckCircleIcon className="h-5 w-5" />
 * <MonetizationOnIcon sx={{ fontSize: 24 }} />
 * 
 * // Need an icon not listed here? Import directly from MUI:
 * import AccountCircleIcon from '@mui/icons-material/AccountCircle';
 * 
 * ============================================================================
 * ADDING NEW ICONS
 * ============================================================================
 * 
 * 1. Find the icon at: https://mui.com/material-ui/material-icons/
 * 2. Add export here with "Icon" suffix:
 *    export { default as YourIconNameIcon } from '@mui/icons-material/YourIconName';
 * 3. Import and use:
 *    import { YourIconNameIcon } from '@/components/icons';
 * 
 * ============================================================================
 */
